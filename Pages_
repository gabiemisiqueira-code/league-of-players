<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Jogador | League of Players</title>
  <link rel="stylesheet" href="../style.css" />
</head>
<body class="dashboard-body">
  <div class="bg-glow bg-glow-1"></div>
  <div class="bg-glow bg-glow-2"></div>

  <header class="navbar">
    <div class="logo">League of Players</div>
    <nav class="nav-links">
      <a href="../index.html">Início</a>
      <a href="../login.html">Login</a>
      <a href="../dashboard.html">Dashboard</a>
      <a href="player.html">Jogador</a>
    </nav>
  </header>

  <main class="dashboard">
    <section class="welcome-card">
      <h2 id="playerTitle">Perfil do Jogador</h2>
      <p id="playerSubtitle">Pesquise um jogador para ver as estatísticas.</p>
    </section>

    <section class="stats-grid">
      <div class="stat-card">
        <h3>Nível</h3>
        <p id="playerLevel">--</p>
      </div>
      <div class="stat-card">
        <h3>ID</h3>
        <p id="playerId">--</p>
      </div>
      <div class="stat-card">
        <h3>Conta</h3>
        <p id="playerAccount">--</p>
      </div>
    </section>

    <section class="ranking-table-section">
      <h2>Buscar jogador</h2>
      <div class="search-box">
        <input type="text" id="playerSearchInput" placeholder="Digite o nick do jogador" />
        <button id="playerSearchBtn">Buscar</button>
      </div>
      <p class="search-hint" id="playerSearchHint"></p>
    </section>
  </main>

  <script src="../js/player.js"></script>
</body>
</html>
